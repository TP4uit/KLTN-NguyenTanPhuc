{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "node20",
    "target": "es2023",
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node", "mocha"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "hardhat.config.ts",
    "ignition/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["artifacts", "cache", "dist", "frontend", "node_modules"]
}
